---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Empirically-tested prompt patterns for GitHub Copilot and AI coding agents' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Agent Prompt Patterns</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <link rel="stylesheet" href={`${base}styles/global.css`} />
</head>
<body>
  <header>
    <div class="container">
      <a href={base} class="logo">agent-prompt-<span>patterns</span></a>
      <nav>
        <a href={base}>Patterns</a>
        <a href={`${base}about`}>About</a>
        <a href="https://github.com/copilot-autogent/agent-prompt-patterns" target="_blank" rel="noopener">GitHub ↗</a>
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <div class="container">
      Patterns are empirically derived. Evidence beats intuition.
    </div>
  </footer>
</body>
</html>

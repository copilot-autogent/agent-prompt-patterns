---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import seedVotes from '../../data/votes.json';

export async function getStaticPaths() {
  const patterns = await getCollection('patterns');
  return patterns.map(pattern => ({
    params: { slug: pattern.id.replace(/\.mdx?$/, '') },
    props: { pattern },
  }));
}

const { pattern } = Astro.props;
const { Content } = await render(pattern);

const base = import.meta.env.BASE_URL;
const patternId = pattern.id.replace(/\.mdx?$/, '');
const allVotes = seedVotes as Record<string, { up: number; down: number }>;
const seedV = allVotes[patternId] ?? { up: 0, down: 0 };
const seedNet = seedV.up - seedV.down;

const categoryLabel = (id: string) => ({
  'prompt-structure': 'Prompt Structure',
  'task-design': 'Task Design',
  'agent-autonomy': 'Agent Autonomy',
  'feedback-loops': 'Feedback Loops',
  'multi-agent': 'Multi-Agent',
}[id] ?? id);

const evidenceLabel = (level: string) => ({
  strong: '[+++] Strong - replicated empirical data',
  moderate: '[++-] Moderate - limited but consistent evidence',
  emerging: '[+--] Emerging - early signal, needs more data',
}[level] ?? level);
---
<Base title={pattern.data.title} description={pattern.data.summary}>
  <div class="container">
    <div style="margin: 1.5rem 0 0;">
      <a href={base} style="color:var(--text-muted);font-size:0.9rem;">&larr; All Patterns</a>
    </div>

    <div class="pattern-page" style="margin-top:1.5rem;">
      <div class="pattern-meta">
        <span class={`badge badge-${pattern.data.category}`}>
          {categoryLabel(pattern.data.category)}
        </span>
        <span class={`evidence-${pattern.data.evidenceLevel}`} style="font-size:0.85rem;">
          {evidenceLabel(pattern.data.evidenceLevel)}
        </span>
      </div>

      <h1>{pattern.data.title}</h1>
      <p class="lead">{pattern.data.summary}</p>

      <!-- Vote widget -->
      <div class="vote-widget" id="vote-widget" data-pattern-id={patternId} data-seed-up={seedV.up} data-seed-down={seedV.down}>
        <button class="vote-btn" id="vote-up" aria-label="Upvote this pattern">
          ▲ <span id="up-count">{seedV.up}</span>
        </button>
        <button class="vote-btn" id="vote-down" aria-label="Downvote this pattern">
          ▼ <span id="down-count">{seedV.down}</span>
        </button>
        <span class="vote-hint" id="vote-net">
          net: <strong id="net-count">{seedNet}</strong>
        </span>
        <span class="vote-hint" style="margin-left:0.25rem;" id="vote-status"></span>
      </div>

      <div class="pattern-body">
        <Content />
      </div>

      {pattern.data.relatedPatterns.length > 0 && (
        <div style="margin-top:3rem; padding-top:1.5rem; border-top:1px solid var(--border);">
          <div class="section-label">Related Patterns</div>
          <div class="related-list">
            {pattern.data.relatedPatterns.map((slug: string) => (
              <a href={`${base}patterns/${slug}`} class="badge badge-prompt-structure" style="font-size:0.85rem;text-transform:none;letter-spacing:0;">
                {slug.replace(/-/g, ' ')}
              </a>
            ))}
          </div>
        </div>
      )}

      {pattern.data.tags.length > 0 && (
        <div style="margin-top:1.5rem;">
          <div class="section-label">Tags</div>
          <div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:0.5rem;">
            {pattern.data.tags.map((tag: string) => (
              <a href={`${base}?tag=${tag}`} style="font-family:var(--font-mono);font-size:0.75rem;color:var(--text-muted);background:var(--bg-card);border:1px solid var(--border);padding:0.15em 0.5em;border-radius:4px;text-decoration:none;" title={`Browse #${tag} patterns`}>
                #{tag}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</Base>

<script>
  import { castVote, getUserVote, mergeWithLocalVotes } from '../../scripts/votes.ts';
  import seedVotesRaw from '../../data/votes.json';

  type VoteStore = Record<string, { up: number; down: number }>;

  let voteController: AbortController | null = null;

  function initVoteWidget() {
    voteController?.abort();
    voteController = new AbortController();
    const { signal } = voteController;

    const widget = document.getElementById('vote-widget');
    if (!widget) return;

    const patternId = widget.dataset.patternId ?? '';
    const seedUp = parseInt(widget.dataset.seedUp ?? '0', 10);
    const seedDown = parseInt(widget.dataset.seedDown ?? '0', 10);
    const seedV = (seedVotesRaw as VoteStore)[patternId] ?? { up: seedUp, down: seedDown };

    const upBtn = document.getElementById('vote-up') as HTMLButtonElement | null;
    const downBtn = document.getElementById('vote-down') as HTMLButtonElement | null;
    const upCount = document.getElementById('up-count');
    const downCount = document.getElementById('down-count');
    const netCount = document.getElementById('net-count');
    const statusEl = document.getElementById('vote-status');

    if (!upBtn || !downBtn) return;

    function refresh(up: number, down: number, userVote: 'up' | 'down' | null) {
      upBtn!.className = `vote-btn${userVote === 'up' ? ' voted-up' : ''}`;
      downBtn!.className = `vote-btn${userVote === 'down' ? ' voted-down' : ''}`;
      if (upCount) upCount.textContent = String(up);
      if (downCount) downCount.textContent = String(down);
      if (netCount) netCount.textContent = String(up - down);
      if (statusEl) {
        statusEl.textContent = userVote === 'up' ? '— you voted ▲' : userVote === 'down' ? '— you voted ▼' : '';
      }
    }

    // Merge seed with local localStorage deltas using the shared helper
    const merged = mergeWithLocalVotes(seedVotesRaw as VoteStore);
    const initial = getUserVote(patternId);
    const mv = merged[patternId] ?? seedV;
    refresh(mv.up, mv.down, initial);

    upBtn.addEventListener('click', () => {
      const { votes, userVote } = castVote(patternId, 'up', seedV);
      refresh(votes.up, votes.down, userVote);
    }, { signal });

    downBtn.addEventListener('click', () => {
      const { votes, userVote } = castVote(patternId, 'down', seedV);
      refresh(votes.up, votes.down, userVote);
    }, { signal });
  }

  document.addEventListener('astro:page-load', initVoteWidget);
</script>
